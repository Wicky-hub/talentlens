# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL and anon key are safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Pinecone ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=talentlens-influencers
# Dimension must match the embedding model output (e.g. 1536 for text-embedding-3-small)
PINECONE_EMBEDDING_DIMENSION=1536

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Apify ────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=your-apify-api-token
APIFY_INSTAGRAM_ACTOR_ID=apify/instagram-scraper
APIFY_TIKTOK_ACTOR_ID=apify/tiktok-scraper
APIFY_YOUTUBE_ACTOR_ID=apify/youtube-scraper

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
